PROJECT_NAME=Silver Voice STT
ENVIRONMENT=development

POSTGRES_DB=silver_voice
POSTGRES_USER=silver_voice
POSTGRES_PASSWORD=silver_voice
DATABASE_URL=postgresql+psycopg://silver_voice:silver_voice@postgres:5432/silver_voice

REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio-files
MINIO_SECURE=false
STORAGE_BACKEND=minio
LOCAL_STORAGE_PATH=apps/api/storage

API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=["http://localhost:3000"]

ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
JWT_SECRET_KEY=change-me-access
JWT_REFRESH_SECRET_KEY=change-me-refresh
JWT_ALGORITHM=HS256

MAX_UPLOAD_MB=100
ALLOWED_AUDIO_TYPES=["audio/wav","audio/x-wav","audio/mpeg","audio/mp3","audio/webm","audio/mp4","audio/x-m4a"]

DEFAULT_MODEL_VERSION=whisper-ko-elderly-v0
LOW_CONFIDENCE_THRESHOLD=0.55
STT_MODEL_BACKEND=faster-whisper
STT_MODEL_PATH=small
STT_DOWNLOAD_ROOT=/workspace/models/cache
STT_COMPUTE_TYPE=int8
STT_DEVICE=cpu
STT_BEAM_SIZE=5
STT_BEST_OF=5
STT_MOCK_MODE=false
STT_CONFIDENCE_CALIBRATION_PATH=
STT_DIARIZATION_MODEL=pyannote/speaker-diarization-community-1
STT_DIARIZATION_DEVICE=cpu
HF_TOKEN=
ENABLE_NOISE_REDUCTION=false

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
